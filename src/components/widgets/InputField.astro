---
import type { HTMLAttributes } from "astro/types";

interface Props extends Omit<HTMLAttributes<"input">, "type" | "class"> {
  label: string;
  type?: "text" | "email" | "tel" | "number" | "password";
  class?: string;
}

const { id, label, type = "text", required, class: className, ...rest } = Astro.props;
const inputId = id || `input-${Math.random().toString(36).substring(2, 9)}`;
---

<div class={`relative text-[17px] my-4 mx-1 h-12 ${className || ""}`}>
  <input
    id={inputId}
    type={type}
    placeholder=" "
    required={required}
    class="peer absolute inset-0 w-full h-full box-border rounded-lg bg-white dark:bg-slate-900 border border-gray-200 dark:border-gray-700 px-4 pl-5 font-semibold text-gray-900 dark:text-gray-100 outline-none transition-all duration-200 ease-in-out focus:border-primary focus:shadow-[0_0_0_3px_color-mix(in_srgb,var(--aw-color-primary)_20%,transparent)] focus:bg-white dark:focus:bg-slate-900"
    {...rest}
  />
  <label
    for={inputId}
    class="pointer-events-none absolute left-5 top-3 z-10 px-0.5 text-gray-500 dark:text-gray-400 font-medium leading-none bg-white dark:bg-slate-900 transition-all duration-200 ease-in-out peer-focus:text-xs peer-focus:leading-[0.8] peer-focus:-translate-y-7 peer-focus:text-primary peer-focus:rounded-[20px] peer-focus:bg-[var(--aw-color-bg-page)] peer-not-placeholder-shown:text-xs peer-not-placeholder-shown:leading-[0.8] peer-not-placeholder-shown:-translate-y-7 peer-not-placeholder-shown:text-primary peer-not-placeholder-shown:rounded-[20px] peer-not-placeholder-shown:bg-[var(--aw-color-bg-page)]"
  >
    {label}{required && <span class="text-primary ml-0.5">*</span>}
  </label>
</div>
