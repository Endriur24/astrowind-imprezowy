---
import type { HTMLAttributes } from "astro/types";

interface Props extends Omit<HTMLAttributes<"textarea">, "class"> {
  label: string;
  minHeight?: string;
  class?: string;
}

const { id, label, required, minHeight = "250px", class: className, ...rest } = Astro.props;
const inputId = id || `textarea-${Math.random().toString(36).substring(2, 9)}`;
---

<div class={`relative text-[17px] my-4 mx-1 ${className || ""}`}>
  <textarea
    id={inputId}
    placeholder=" "
    required={required}
    style={`min-height: ${minHeight};`}
    class="peer w-full box-border rounded-lg rounded-r-md bg-white dark:bg-slate-900 border border-gray-200 dark:border-gray-700 py-3.5 px-5 font-semibold text-gray-900 dark:text-gray-100 outline-none resize-y transition-all duration-200 ease-in-out focus:border-primary focus:shadow-[0_0_0_3px_color-mix(in_srgb,var(--aw-color-primary)_20%,transparent)] focus:bg-white dark:focus:bg-slate-900 [&::-webkit-scrollbar]:w-4 [&::-webkit-scrollbar-track]:bg-gray-100 dark:[&::-webkit-scrollbar-track]:bg-gray-800 [&::-webkit-scrollbar-track]:rounded-lg [&::-webkit-scrollbar-thumb]:bg-gray-300 dark:[&::-webkit-scrollbar-thumb]:bg-gray-600 [&::-webkit-scrollbar-thumb]:rounded-lg [&::-webkit-scrollbar-thumb]:border-3 [&::-webkit-scrollbar-thumb]:border-gray-100 dark:[&::-webkit-scrollbar-thumb]:border-gray-800 hover:[&::-webkit-scrollbar-thumb]:bg-gray-400 dark:hover:[&::-webkit-scrollbar-thumb]:bg-gray-500 [&::-webkit-scrollbar-corner]:bg-gray-100 dark:[&::-webkit-scrollbar-corner]:bg-gray-800 [&::-webkit-resizer]:bg-transparent"
    {...rest}
  ></textarea>
  <label
    for={inputId}
    class="floating-label pointer-events-none absolute left-5 top-5 z-10 px-0.5 text-gray-500 dark:text-gray-400 font-medium leading-none bg-white dark:bg-slate-900 transition-all duration-200 ease-in-out peer-focus:text-xs peer-focus:leading-[0.8] peer-focus:-translate-y-7 peer-focus:bg-white dark:peer-focus:bg-slate-900 peer-focus:text-primary peer-focus:rounded-[20px]"
  >
    {label}{required && <span class="text-primary ml-0.5">*</span>}
  </label>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const textareas = document.querySelectorAll('textarea[placeholder=" "]');
    
    textareas.forEach((textarea) => {
      const label = textarea.parentElement?.querySelector('.floating-label');
      if (!label) return;
      
      const updateLabel = () => {
        if ((textarea as HTMLTextAreaElement).value.trim() !== '') {
          label.classList.add('label-active');
        } else {
          label.classList.remove('label-active');
        }
      };
      
      textarea.addEventListener('input', updateLabel);
      textarea.addEventListener('blur', updateLabel);
      updateLabel();
    });
  });
</script>

<style>
  .label-active {
    font-size: 0.75rem;
    line-height: 0.8;
    transform: translateY(-1.75rem);
    background-color: white;
    color: var(--aw-color-primary);
    border-radius: 20px;
  }
  
  :global(.dark) .label-active {
    background-color: rgb(15 23 42);
  }
</style>
