---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = `Strona nie została znaleziona`;
---

<Layout metadata={{ title }}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Błąd</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">Strona nie została znaleziona</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          Wygląda na to, że ta strona nie istnieje. Sprawdź naszą stronę główną lub ofertę.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a rel="noopener noreferrer" href={getHomePermalink()} class="btn">Strona główna</a>
          <a href="/oferta" class="btn btn-outline">Zobacz ofertę</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
