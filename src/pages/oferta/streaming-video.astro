---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

import streamingVideoCover from '~/assets/images/covers/streaming_video_cover.jpg';

const metadata = {
  title: 'Streaming video - ImprezowyFotograf',
  description: 'Profesjonalne transmisje live z konferencji i wydarzeń, webinary, programy dedykowane. Pełna obsługa audio i wideo.',
};
---

<Layout metadata={metadata}>
  <Hero
    image={{ 
      src: streamingVideoCover, 
      alt: 'Streaming wideo'
    }}
  >
    <Fragment slot="title">
      Streaming wideo
    </Fragment>
  </Hero>

  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="prose prose-lg dark:prose-invert max-w-none">
        <h2>Realizujemy transmisje wideo</h2>
        <p>Transmisje live z konferencji, wykładów, prelekcji, prezentacji i wywiadów - zarówno w formie 100% zdalnej jak i hybrydowej - to również element naszej oferty! Realizujemy live wideo z eventów, a także produkujemy webinary i programy dedykowane (w stylu telewizyjnym). Mamy w swoich szeregach realizatorów audio, wideo, operatorów kamer oraz grafików tworzących materiały wizualne na potrzeby transmisji.</p>
        <p>Tego typu realizacje są bardzo zróżnicowane - zawłaszcza pod kątem liczby potrzebnej kadry, sprzętu, opracowania logistyki oraz planu działania i innych rozwiązań technicznych. Dopasowujemy wszystkie te parametry do potrzeb i budżetu klienta, tak by zapewnić najwyższy stosunek jakości do ceny.</p>
        <p>Nasza doświadczona kadra obsługiwała m.in. konferencje z dostępem tak publicznym jak i prywatnym, standardowe i hybrydowe, transmisje z obsługą połączeń telefonicznych, a także studia live z wywiadami na żywo i dużą liczbą materiałów multimedialnych.</p>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <ContactForm
    formName="formularz-streaming"
    title="Zapytaj o streaming wideo"
    description="Wypełnij formularz, a skontaktujemy się z Tobą w sprawie streamingu wideo."
  />
</Layout>
