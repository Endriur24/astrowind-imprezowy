---
import Layout from '../../layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

import dodatkoweUslugiCover from '~/assets/images/covers/dodatkowe_uslugi_cover.jpg';

const metadata = {
  title: 'Dodatkowe usługi fotograficzne - ImprezowyFotograf',
  description: 'Nasza wszechstronna wiedza i doświadczenie pozwalają nam na bardzo szerokie rozszerzanie usług. Pytaj śmiało o nietypowe realizacje!',
};
---

<Layout metadata={metadata}>
  <Hero
    image={{ 
      src: dodatkoweUslugiCover, 
      alt: 'Dodatkowe usługi foto/wideo'
    }}
  >
    <Fragment slot="title">
      Dodatkowe usługi foto/wideo
    </Fragment>
  </Hero>

  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="prose prose-lg dark:prose-invert max-w-none">
        <h2>Ożywiamy imprezy niecodziennym podejściem</h2>
        <p>Fotograf to człowiek z aparatem cyfrowym. Operator / filmowiec - z cyfrową kamerą. Ale czy zawsze? My pokazujemy, że niekoniecznie! Oprócz standardowego reportażu w naszej ofercie znajdują się trochę mniej lub bardziej oczywiste pozycje, m.in.:</p>
        <ul>
          <li><strong>zdjęcia i filmy z drona</strong>,</li>
          <li><strong>ścianka fotograficzna</strong>, czyli zdjęcia na jednolitym lub zaaranżowanym tle, światło błyskowe lub ciągłe,</li>
          <li><strong>ścianka fotograficzna "live"</strong> - zdjęcia "w czasie rzeczywistym" na udostępnionym serwerze,</li>
          <li><strong>ścianka fotograficzna z wydrukiem</strong> - zdjęcia w druku na następny dzień (lub w czasie rzeczywistym),</li>
          <li><strong>fotoedytor na miejscu</strong> - zdjęcia z wydarzenia "w czasie rzeczywistym" na serwerze,</li>
          <li><strong>zdjęcia instant</strong> - fotograf z aparatem typu Instax lub możliwość wydruku zdjęć cyfrowych na nośnikach Instax,</li>
          <li><strong>nagrania kamerą VHS</strong> - specyficzny typ realizacji, bardzo ograniczony ze względu na małą dostępność działającego sprzętu,</li>
          <li><strong>zdjęcia na błonie filmowej</strong> - również charakterystyczny rodzaj realizacji, także ograniczony ze względu na dostępność działającego sprzętu oraz materiałów światłoczułych,</li>
          <li><strong>streaming wideo live do internetu</strong> - realizacje live z prelekcji, wykładów, konferencji itp.,</li>
          <li><strong>fotobudka</strong>.</li>
        </ul>
        <p>Zachęcamy do kontaktu i wcześniejszego zamawiania tego typu usług ze względu na ograniczenia w dostępności sprzętu, materiałów i zasobów kadrowych.</p>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <ContactForm
    formName="formularz-dodatkowe"
    title="Zapytaj o dodatkowe usługi"
    description="Wypełnij formularz, a skontaktujemy się z Tobą w sprawie dodatkowych usług fotograficznych."
  />
</Layout>
