---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Contact from '~/components/widgets/Contact.astro';
import Gallery from '~/components/widgets/Gallery.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

import studniowkiCover from '~/assets/images/covers/studniowki_cover.jpg';

const metadata = {
  title: 'Fotograf na Studniówkę Kraków — Zdjęcia, Wideo, Komers | ImprezowyFotograf',
  description: 'Profesjonalny fotograf na studniówkę i komers w Krakowie. Retusz w cenie, zdjęcia grupowe, ścianka, teledysk wideo. Pakiety od 1 fotografa do 3+. Sprawdź ofertę!',
  canonical: 'https://imprezowyfotograf.pl/oferta/fotograf-na-studniowke',
  openGraph: {
    url: 'https://imprezowyfotograf.pl/oferta/fotograf-na-studniowke',
    locale: 'pl_PL',
    type: 'website',
    title: 'Fotograf na Studniówkę Kraków — Zdjęcia, Wideo, Komers',
    description: 'Profesjonalny fotograf na studniówkę w Krakowie. Retusz w cenie, pakiety od 1 do 3+ fotografów.',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Imprezowy Fotograf - Fotografia na Studniówkę",
    "description": "Profesjonalny fotograf na studniówkę w Krakowie. Zdjęcia pełne energii i nowoczesności, retusz w cenie.",
    "url": "https://imprezowyfotograf.pl/oferta/fotograf-na-studniowke",
    "image": "https://imprezowyfotograf.pl/assets/images/covers/studniowki_cover.jpg",
    "areaServed": [
      {"@type": "City", "name": "Kraków"},
      {"@type": "City", "name": "Warszawa"},
      {"@type": "City", "name": "Katowice"},
      {"@type": "Country", "name": "Polska"}
    ],
    "serviceType": ["Fotografia na studniówkę", "Fotografia imprezowa", "Zdjęcia live"],
    "priceRange": "$$"
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Ile kosztuje fotograf na studniówkę?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cena fotografa na studniówkę zależy od wybranego pakietu. Oferujemy pakiety od Podstawowego (1 fotograf, 500 zdjęć, 5h reportażu) po pakiet Imprezowy+ (3+ fotografów, 1500+ zdjęć, ścianka, teledysk wideo). Dokładne wyceny otrzymacie po kontakcie — dopasowujemy ofertę do Waszych potrzeb i budżetu."
        }
      },
      {
        "@type": "Question",
        "name": "Jak szybko otrzymamy zdjęcia ze studniówki?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standardowy czas dostarczenia zdjęć ze studniówki to 5-7 dni roboczych. Oferujemy również usługę zdjęć live — wtedy na lokację zabieramy fotoedytora, który przygotowuje pierwsze partie zdjęć jeszcze podczas trwania wydarzenia."
        }
      },
      {
        "@type": "Question",
        "name": "Czy retuszujecie zdjęcia ze studniówki?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tak! W przeciwieństwie do większości fotografów na rynku, my retuszujemy wszystkie zdjęcia ze studniówek. Wiemy, że studniówkę ma się tylko raz, dlatego chcemy, żebyście wyglądali na zdjęciach jak najlepiej."
        }
      },
      {
        "@type": "Question",
        "name": "Czy oferujecie wideo na studniówkę?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tak! W pakiecie Imprezowy+ teledysk wideo jest wliczony. W pozostałych pakietach można go dodać jako opcję dodatkową. Oferujemy również film na studniówkę — materiał nagrany wcześniej, który pokażecie podczas części artystycznej."
        }
      },
      {
        "@type": "Question",
        "name": "Na jakim terenie fotografujecie studniówki?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Studniówki fotografujemy najczęściej na terenie Krakowa i województwa małopolskiego, ale dojeżdżamy również na terenie podkarpackiego, śląskiego, świętokrzyskiego oraz całej Polski. Jeśli tego wymaga wydarzenie — dojedziemy lub dolecimy, gdzie trzeba!"
        }
      }
    ]
  })} />

  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Sprawdź naszą ofertę!',
        href: '#studniowka-1',
      },
    ]}
    image={{ 
      src: studniowkiCover, 
      alt: 'Fotograf na studniówkę i komers w Krakowie',
      width: 1200,
      height: 600
    }}
  >
    <Fragment slot="title">
      Fotograf na Studniówkę i Komers w Krakowie
    </Fragment>
    <Fragment slot="subtitle">
      Profesjonalna <strong>fotografia studniówkowa w Krakowie</strong> — retusz w cenie, zdjęcia grupowe klas, ścianka, teledysk wideo. Pakiety od 1 do 3+ fotografów.
    </Fragment>
  </Hero>

  <!-- SEO Content Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">Fotografia studniówkowa w Krakowie</h2>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        Szukasz <strong>fotografa na studniówkę w Krakowie</strong>? Jesteś w dobrym miejscu! Specjalizujemy się w <strong>fotografii studniówkowej</strong> — uwieczniamy ten wyjątkowy wieczór pełen emocji, radości i pożegnania ze szkołą. Nasza ekipa to młodzi, energiczni fotografowie, którzy czują studniówkowy klimat i wiedzą, jak uchwycić najlepsze momenty.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        W naszej ofercie studniówkowej znajdziecie <strong>pakiety od 1 do 3+ fotografów</strong>, ze zdjęciami grupowymi klas, <strong>ścianką fotograficzną</strong>, <strong>teledyskiem wideo</strong> i wieloma opcjami dodatkowymi. Wszystkie pakiety zawierają <strong>retusz zdjęć w cenie</strong> — w przeciwieństwie do większości fotografów na rynku.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto text-center">
        Studniówki fotografujemy głównie na terenie <strong>Krakowa</strong> i województwa <strong>małopolskiego</strong>, ale dojeżdżamy również na terenie <strong>podkarpackiego</strong>, <strong>śląskiego</strong>, <strong>świętokrzyskiego</strong> oraz <strong>całej Polski</strong>.
      </p>
    </div>
  </section>

  <!-- Main Content Section -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="text-center mb-12">
        <p class="text-base text-blue-600 dark:text-blue-400 font-semibold tracking-wide uppercase">Wybór fotografa na studniówkę</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mt-2 mb-4">Na co zwrócić uwagę przy wyborze fotografa na studniówkę?</h2>
      </div>
      <div class="max-w-4xl mx-auto space-y-8">
        <div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Sprawdź portfolio fotografa</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400">Po pierwsze, ważne jest, aby sprawdzić portfolio potencjalnego fotografa. Przeglądając jego wcześniejsze prace, można ocenić jego styl i umiejętności. To pozwoli określić, czy jego prace po prostu wam odpowiadają. Starannie przeglądając portfolio, można również zidentyfikować, czy fotograf posiada doświadczenie w fotografowaniu imprez okolicznościowych, takich jak studniówki. Ponadto warto zaglądnąć do przykładowych realizacji również z innych dziedzin, często będzie to fotografia ślubna, klubowa, reklamowa czy jeszcze inna.</p>
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Dobry kontakt to podstawa</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400">Kolejnym super ważnym aspektem jest komunikacja. Studniówka to przede wszystkim dobra zabawa i ważne abyście Wy dobrze czuli się w obecności swoich fotografów. Potrzebne jest do tego trochę zaufania jak również ekipa foto/video musi czuć ten studniówkowy nastrój. Dobry fotograf powinien być otwarty na Wasze sugestie i pytania oraz służyć radą na przykład w kwestii tego jak wykonać zdjęcia grupowe. Dlatego warto spotkać się z fotografem osobiście lub przynajmniej przeprowadzić rozmowę telefoniczną, aby omówić szczegóły związane z planem studniówki i wyrazić swoje oczekiwania.</p>
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Przejrzysty cennik</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400">Fotografia studniówkowa może być wyceniana na różne sposoby. Jedni fotografowie przedstawiają wyceny w przeliczeniu na osobę a inni tak jak my oferują pakiety oparte na ilości fotografów dostarczających daną ilość zdjęć. W naszej ocenie jest to bardziej sprawiedliwa wycena zdjęć studniówkowych natomiast zdajemy sobie sprawę, że oferta przedstawiona w ten sposób może być na początku dla was nieco kłopotliwa dlatego w razie wątpliwości zapraszamy do kontaktu.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Us Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <div class="text-center mb-12">
        <p class="text-base text-blue-600 dark:text-blue-400 font-semibold tracking-wide uppercase">Dlaczego my?</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mt-2 mb-4">Dlaczego fotograf na studniówkę z imprezowyfotograf.pl?</h2>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">Nasi profesjonalni fotografowie zadbają o giga czadowe utrwalenie Waszego pożegnania się ze szkołą!</p>
      </div>
      <div class="max-w-4xl mx-auto space-y-8">
        <div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Średni czas oczekiwania na zdjęcia</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400">Doskonale zdajemy sobie sprawę z tego, jak ważną rolę ma dla Was czas przekazania zdjęć. Staramy się pracować sprawnie i szybko, jednocześnie zachowując najwyższą możliwą jakość. W przypadku zdjęć ze studniówek standardowy czas dostarczenia zdjęć to zazwyczaj 5-7 dni roboczych. Mamy również w ofercie możliwość wykonania tzw. zdjęć live - wtedy zabieramy ze sobą na lokację fotoedytora.</p>
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Retuszujemy zdjęcia!</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400">Wielu fotografów na polskim rynku nie wykonuje retuszu skóry na zdjęciach reportażowych. Dlaczego? Ponieważ retusz zabiera dużo czasu, a obrobione w ten sposób zdjęcia sporo przestrzeni dyskowej. My jednak idziemy pod prąd tego nurtu i retuszujemy wszystkie zdjęcia z Waszych studniówek! Robimy to, ponieważ wiemy, że jest to dla Was ważne - w końcu studniówkę ma się tylko raz!</p>
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Gdzie działamy</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400">Naszym rodzimym miastem jest Kraków dlatego najczęściej fotografujemy na terenie województwa małopolskiego, podkarpackiego, śląskiego oraz świętokrzyskiego jednak dojeżdżamy na terenie całej Polski, a jeśli tego wymaga wydarzenie - dojedziemy lub dolecimy gdzie trzeba!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Gallery -->
  <Gallery 
    folderPath="portfolio/studniowka" 
    title="Portfolio"
    subtitle="Poniżej wrzucamy trochę kadrów pokazujących, jak mogą wyglądać zdjęcia z Waszej studniówki!"
    minColumnWidth={200}
    gap={12}
  />

  <!-- Pricing Section -->
  <section id="studniowka-1" class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Oferta</h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">Przyszedł czas na naszą ofertę. Wybierzcie pakiet, który odpowiada Waszym oczekiwaniom albo skontaktujcie się z nami w celu ułożenia lub dopasowania pakietu specjalnie dla Was!</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gray-50 dark:bg-gray-800 p-8 rounded-lg">
          <div class="text-center mb-6">
            <h4 class="text-2xl font-bold">PODSTAWOWY</h4>
            <div class="inline-block bg-amber-500 text-white px-3 py-1 rounded-full text-sm mt-2">Brązowy</div>
          </div>
          <p class="text-center text-lg mb-6">1 fotograf</p>
          <ul class="space-y-2 mb-8">
            <li>Zdjęć po obróbce: <strong>500</strong></li>
            <li>Godzin reportażu: <strong>5h</strong></li>
            <li>Retusz w cenie: <strong>Tak</strong></li>
            <li>Zdjęcia grupowe klas: <strong>Tak</strong></li>
            <li>Ścianka: <strong>Nie</strong></li>
            <li>Teledysk wideo: <strong>Nie</strong></li>
          </ul>
          <a href="#kontakt" class="block w-full bg-blue-600 text-white py-3 px-6 rounded-md text-center hover:bg-blue-700 transition-colors">Zapytaj o termin!</a>
        </div>
        <div class="bg-gray-50 dark:bg-gray-800 p-8 rounded-lg">
          <div class="text-center mb-6">
            <div class="inline-block bg-gray-400 text-white px-3 py-1 rounded-full text-sm mt-2">Srebrny</div>
            <h4 class="text-2xl font-bold">ROZSZERZONY</h4>
          </div>
          <p class="text-center text-lg mb-6">2 fotografów</p>
          <ul class="space-y-2 mb-8">
            <li>Zdjęć po obróbce: <strong>1000</strong></li>
            <li>Godzin reportażu: <strong>5h</strong></li>
            <li>Retusz w cenie: <strong>Tak</strong></li>
            <li>Zdjęcia grupowe klas: <strong>Tak</strong></li>
            <li>Ścianka: <strong>Nie</strong></li>
            <li>Teledysk wideo: <strong>Nie</strong></li>
          </ul>
          <a href="#kontakt" class="block w-full bg-blue-600 text-white py-3 px-6 rounded-md text-center hover:bg-blue-700 transition-colors">Zapytaj o termin!</a>
        </div>
        <div class="bg-gradient-to-r from-yellow-400 to-yellow-600 text-white p-8 rounded-lg relative">
          <div class="text-center mb-6">
            <h4 class="text-2xl font-bold">IMPREZOWY+</h4>
            <div class="inline-block bg-yellow-700 text-white px-3 py-1 rounded-full text-sm mt-2">Złoty</div>
          </div>
          <p class="text-center text-lg mb-6">3 fotografów (lub więcej)<br>1 operator kamery</p>
          <ul class="space-y-2 mb-8">
            <li>Zdjęć po obróbce: <strong>1500+</strong></li>
            <li>Godzin reportażu: <strong>5h</strong></li>
            <li>Retusz w cenie: <strong>Tak</strong></li>
            <li>Zdjęcia grupowe klas: <strong>Tak</strong></li>
            <li>Ścianka: <strong>Tak</strong></li>
            <li>Teledysk wideo: <strong>Tak</strong></li>
          </ul>
          <a href="#kontakt" class="block w-full bg-white text-yellow-600 py-3 px-6 rounded-md text-center font-bold hover:bg-gray-100 transition-colors">Zapytaj o termin!</a>
        </div>
      </div>
      <div class="mt-12">
        <h4 class="text-2xl font-bold text-center text-gray-900 dark:text-white mb-6">Opcje dodatkowe</h4>
        <div class="max-w-4xl mx-auto">
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-6 text-center">Oprócz podstawowego zakresu, do pakietów można dobrać opcje dodatkowe. Istnieje również możliwość skomponowania oferty od podstaw bazując na Waszych oczekiwaniach i konkretnych wytycznych.</p>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 text-lg">
            <li>• dodatkowy fotograf, czyli +500 zdjęć</li>
            <li>• ścianka - zdjęcia na jednolitym lub zaaranżowanym tle</li>
            <li>• ścianka live - zdjęcia "w czasie rzeczywistym" na udostępnionym serwerze</li>
            <li>• fotoedytor na miejscu - zdjęcia z wydarzenia "w czasie rzeczywistym" na serwerze</li>
            <li>• film na studniówkę - materiał nagrany wcześniej, który pokażecie podczas części artystycznej wydarzenia</li>
            <li>• nagrania / zdjęcia drona - np. jako dodatek do teledysku wideo albo zdjęcia grupowe w plenerze</li>
            <li>• fotobudka</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Najczęstsze pytania — fotografia studniówkowa</h2>
      <div class="max-w-3xl mx-auto space-y-8">
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Ile kosztuje fotograf na studniówkę?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Cena fotografa na studniówkę zależy od wybranego pakietu. Oferujemy pakiety od <strong>Podstawowego</strong> (1 fotograf, 500 zdjęć, 5h reportażu) po pakiet <strong>Imprezowy+</strong> (3+ fotografów, 1500+ zdjęć, ścianka, teledysk wideo). Dokładne wyceny otrzymacie po kontakcie — dopasowujemy ofertę do Waszych potrzeb i budżetu.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Jak szybko otrzymamy zdjęcia ze studniówki?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Standardowy czas dostarczenia zdjęć ze studniówki to <strong>5-7 dni roboczych</strong>. Istnieje możliwość szybszego oddania w <strong>72h lub 24h</strong>. Oferujemy również usługę <strong>live edit</strong>, gdzie zdjęcia oddawane są jeszcze w trakcie trwania wydarzenia.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Czy retuszujecie zdjęcia ze studniówki?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Tak! W przeciwieństwie do większości fotografów na rynku, my <strong>retuszujemy wszystkie zdjęcia</strong> ze studniówek. Wiemy, że studniówkę ma się tylko raz, dlatego chcemy, żebyście wyglądali na zdjęciach jak najlepiej.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Czy oferujecie wideo na studniówkę?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Tak! W pakiecie <strong>Imprezowy+</strong> teledysk wideo jest wliczony. W pozostałych pakietach można go dodać jako opcję dodatkową. Oferujemy również <a href="/oferta/video-eventowe" class="text-blue-600 dark:text-blue-400 hover:underline">film na studniówkę</a> — materiał nagrany wcześniej, który pokażecie podczas części artystycznej.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Na jakim terenie fotografujecie studniówki?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Studniówki fotografujemy najczęściej na terenie <strong>Krakowa</strong> i województwa <strong>małopolskiego</strong>, ale dojeżdżamy również na terenie <strong>podkarpackiego</strong>, <strong>śląskiego</strong>, <strong>świętokrzyskiego</strong> oraz <strong>całej Polski</strong>. Jeśli tego wymaga wydarzenie — dojedziemy lub dolecimy, gdzie trzeba!
          </p>
        </div>
      </div>
    </div>
