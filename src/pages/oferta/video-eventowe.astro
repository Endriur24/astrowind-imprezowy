---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

import videoEventoweCover from '~/assets/images/covers/video_eventowe_cover.jpg';

const metadata = {
  title: 'Wideo eventowe Kraków - ImprezowyFotograf',
  description: 'Możemy zaoferować kompleksową usługę video z wszelkiego rodzaju eventów zarówno organizowanych przez firmy jak i uczelnie.',
};
---

<Layout metadata={metadata}>
  <Hero
    image={{ 
      src: videoEventoweCover, 
      alt: 'Wideo eventowe'
    }}
  >
    <Fragment slot="title">
      Wideo eventowe
    </Fragment>
    <Fragment slot="subtitle">
      (I NIE TYLKO)
    </Fragment>
  </Hero>

  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="prose prose-lg dark:prose-invert max-w-none">
        <h2>Opowiadamy historie.</h2>
        <p>Uwielbiamy relacjonować przebieg zdarzeń, opowiadać historie i zapisywać wspomnienia. Do reportaży fotograficznych, z punktu widzenia storytellingu, podchodzi się w zupełnie inny sposób niż do relacji wideo. Obie te formy realizują również różne potrzeby klientów i wzajemnie się uzupełniają. Z tego powodu w naszej ofercie obok standardowych reportaży fotograficznych musiało znaleźć się miejsce również na odpowiedniki wideo.</p>
        <p>Jednak reportaże to nie wszystko. Oprócz standardowych relacji eventowych oferujemy również produkcję innych form filmowych, m.in.: teledysków, filmów i spotów promocyjnych, nagrań wywiadów i wypowiedzi (setek), filmów instruktażowych, kursów edukacyjnych, podcastów wideo (i lub audio), filmów z drona, materiałów reklamowych, wizerunkowych, case study i innych.</p>
        <p>Nie tylko nagrywamy, ale również montujemy - jeśli zachodzi taka potrzeba nurkujemy w oceanie materiałów stock i tworzymy wideo zgodnie z wytycznymi przekazanymi przez klienta. Nagrywamy i post produkujemy również audio lektorskie.</p>
        <p>W zakresie wideo pracujemy głównie w południowej części Polski, ale jeśli tego trzeba - dojeżdżamy, gdzie trzeba - niezależnie od tego, czy w kraju, czy za granicę.</p>
        <p>Ze względu na bardzo duże zróżnicowanie w projektach wideo - do tej pory nie zdarzyło nam się realizować dwóch takich samych - każde zapytanie analizujemy indywidualnie na podstawie wytycznych przesłanych przez klienta. Zachęcamy do kontaktu przez formularz lub telefonicznie.</p>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <ContactForm
    formName="formularz-video-eventowe"
    title="Zapytaj o wideo eventowe"
    description="Wypełnij formularz, a skontaktujemy się z Tobą w sprawie wideo eventowego."
  />
</Layout>
