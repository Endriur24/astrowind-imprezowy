---
import Layout from '../../layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';
import OfferFaq from '~/components/offer/OfferFaq.astro';
import { createOfferPageGraph, siteUrl } from '~/utils/schema';

import zdjeciaLiveCover from '~/assets/images/covers/zdjecia_live_cover.jpg';

const faqData = [
  { question: "Co to są zdjęcia live?", answer: "Zdjęcia live to usługa fotograficzna, w której zdjęcia są dostarczane <strong>niemal w czasie rzeczywistym</strong> — jeszcze podczas trwania wydarzenia. Na miejsce wysyłamy fotografa i fotoedytora, który na bieżąco przygotowuje pliki do publikacji." },
  { question: "Ile kosztują zdjęcia live?", answer: "Koszt zdjęć live zależy od specyfiki wydarzenia, liczby godzin i wymaganej kadry. Usługa obejmuje <strong>fotografa oraz fotoedytora</strong> na miejscu. Zapraszamy do kontaktu po indywidualną wycenę." },
  { question: "Jak szybko dostajemy zdjęcia?", answer: "Pierwsze partie zdjęć live trafiają do klienta jeszcze <strong>w trakcie trwania wydarzenia</strong> — zazwyczaj w ciągu kilkunastu minut od wykonania. Pełny reportaż retuszowany dostarczamy w standardowym terminie 24-72h." },
  { question: "Na jakim terenie oferujecie zdjęcia live?", answer: "Zdjęcia live oferujemy na terenie <strong>całej Polski</strong>. Dojeżdżamy do Krakowa, Warszawy, Katowic, Rzeszowa, Wrocławia, Gdańska i innych miast. Możliwe są również realizacje za granicą." },
];

const faqSchemaItems = faqData.map(q => ({ name: q.question, acceptedAnswer: { text: q.answer } }));

const schema = createOfferPageGraph({
  serviceName: "Zdjęcia Live — Fotografia w Czasie Rzeczywistym",
  serviceDescription: "Dostarczamy zdjęcia niemal w czasie rzeczywistym, jeszcze w trakcie trwania wydarzenia. Fotoedytor na miejscu.",
  serviceUrl: `${siteUrl}/oferta/zdjecia-live`,
  faqItems: faqSchemaItems,
  breadcrumbItems: [
    { position: 1, name: "Strona główna", item: siteUrl },
    { position: 2, name: "Oferta", item: `${siteUrl}/oferta` },
    { position: 3, name: "Zdjęcia live" },
  ],
});

const metadata = {
  title: 'Zdjęcia Live — Fotografia w Czasie Rzeczywistym na Eventy | ImprezowyFotograf',
  description: 'Zdjęcia live — dostarczamy zdjęcia niemal w czasie rzeczywistym, jeszcze podczas trwania wydarzenia. Fotoedytor na miejscu, szybka publikacja na social media. Sprawdź!',
  canonical: 'https://imprezowyfotograf.pl/oferta/zdjecia-live',
  openGraph: {
    url: 'https://imprezowyfotograf.pl/oferta/zdjecia-live',
    locale: 'pl_PL',
    type: 'website',
    title: 'Zdjęcia Live — Fotografia w Czasie Rzeczywistym na Eventy',
    description: 'Zdjęcia live — dostarczamy zdjęcia niemal w czasie rzeczywistym. Fotoedytor na miejscu, szybka publikacja na social media.',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Hero
    image={{ 
      src: zdjeciaLiveCover, 
      alt: 'Zdjęcia live — fotografia w czasie rzeczywistym na eventach'
    }}
    actions={[
      {
        variant: 'primary',
        text: 'Zapytaj o zdjęcia live',
        href: '/kontakt',
      },
      {
        variant: 'secondary',
        text: 'Zobacz portfolio',
        href: '/portfolio',
      },
    ]}
  >
    <Fragment slot="title">
      Zdjęcia "live"
    </Fragment>
    <Fragment slot="subtitle">
      <strong>Dostarczamy zdjęcia w czasie rzeczywistym</strong> — jeszcze podczas trwania wydarzenia. Fotoedytor na miejscu, szybka publikacja na social media.
    </Fragment>
  </Hero>

  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">Zdjęcia live na event — fotografia w czasie rzeczywistym</h2>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        Szukasz <strong>zdjęć live na event</strong>? Nasza usługa <strong>fotografii w czasie rzeczywistym</strong> pozwala na otrzymywanie zdjęć niemal natychmiast — jeszcze w trakcie trwania wydarzenia. Na miejsce wysyłamy fotografa i <strong>fotoedytora</strong>, który na bieżąco przygotowuje pliki do publikacji.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        <strong>Zdjęcia live</strong> to idealne rozwiązanie na konferencje, eventy firmowe i wydarzenia studenckie, gdzie organizator chce publikować materiały na bieżąco na <strong>social media</strong>. Pierwsze zdjęcia trafiają do Ciebie w ciągu kilkunastu minut od wykonania.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto text-center">
        Oferujemy zdjęcia live na terenie <strong>całej Polski</strong> — Kraków, Warszawa, Katowice, Wrocław, Gdańsk i więcej. Istnieje również możliwość dostarczenia zdjęć w formie <strong>papierowej</strong> od razu lub na następny dzień.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="prose prose-lg dark:prose-invert max-w-none">
        <h2>Fotografujemy, edytujemy, dostarczamy. Natychmiast.</h2>
        <p>Zdarzają się takie eventy, gdzie organizator chciałby otrzymać zdjęcia dużo wcześniej, niż zwykle się to praktykuje. Czasami jest to kilka godzin od wydarzenia, czasem następny dzień rano, a w innych przypadkach materiały potrzebne są tu i teraz. Z myślą o takich realizacjach stworzyliśmy system pracy umożliwiający optymalizację czasu potrzebnego na dostarczenie zdjęć.</p>
        <p>W zależności od specyfiki projektu na wydarzenie wysyłamy tylko fotografa lub fotografa i <strong>fotoedytora</strong>. Fotoedytor otrzymuje od fotografa pliki RAW (różnymi metodami technicznymi, dobieranymi indywidualnie do specyfiki wydarzenia) i przygotowuje na miejscu pliki do publikacji, a następnie wykonuje ich transfer na wcześniej przygotowany do tego celu hosting plików.</p>
        <p>Zdarzają się również realizacje, gdzie zdjęcia są potrzebne w formie <strong>papierowej</strong> od razu lub na następny dzień po zdjęciach — istnieje również możliwość realizacji tego typu zlecenia.</p>
        <p>Jako, że usługa zdjęć "live" jest dość unikalną usługą i niewiele firm ją oferuje — dojeżdżamy na terenie <strong>całej Polski</strong>, a jeśli tego trzeba — możemy również dolecieć!</p>
        <p>Realizujemy live również <strong>audio i wideo</strong> — zapraszamy do zapoznania się z ofertą na stronie dotyczącej <a href="/oferta/streaming-video">streamingu</a>.</p>
      </div>
    </div>
  </section>

  <OfferFaq
    heading="Najczęstsze pytania — zdjęcia live"
    items={faqData}
  />

  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8 text-center">Sprawdź również nasze inne usługi</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <a href="/oferta/fotograf-na-konferencje-krakow" class="group block bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400 transition-colors">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400">Fotograf na konferencję</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Profesjonalna dokumentacja konferencji i kongresów.</p>
        </a>
        <a href="/oferta/streaming-video" class="group block bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400 transition-colors">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400">Streaming video</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Transmisje live z konferencji, wykładów i eventów.</p>
        </a>
        <a href="/oferta/dodatkowe-uslugi-fotograficzne" class="group block bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400 transition-colors">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400">Dodatkowe usługi</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Fotobudka, studio fotograficzne, photowall, wydruki i inne dodatki na eventy.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <ContactForm
    formName="formularz-zdjecia-live"
    title="Zapytaj o zdjęcia live"
    description="Wypełnij formularz, a skontaktujemy się z Tobą w sprawie zdjęć live."
  />
</Layout>
