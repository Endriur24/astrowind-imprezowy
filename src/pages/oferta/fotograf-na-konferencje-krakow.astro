---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

const metadata = {
  title: 'Fotograf na Konferencję Kraków | Profesjonalna Fotografia Eventowa',
  description: 'Profesjonalny fotograf na konferencje i eventy firmowe w Krakowie, Warszawie, Katowicach. Zdjęcia w 24h, retusz w cenie, fotografia live na LinkedIn i social media. Sprawdź ofertę!',
  openGraph: {
    type: 'website',
    locale: 'pl_PL',
    site_name: 'Imprezowy Fotograf',
    title: 'Fotograf na Konferencję | Imprezowy Fotograf',
    description: 'Profesjonalna fotografia konferencyjna i eventowa. Zdjęcia w 24h, retusz w cenie, obsługa w całej Polsce.',
  },
  canonical: 'https://imprezowyfotograf.pl/oferta/fotograf-na-konferencje-krakow',
};

import KonferencjeCover from '~/assets/images/covers/konferencje_cover.jpg';
---

<Layout metadata={metadata}>
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Imprezowy Fotograf - Fotografia Konferencyjna",
    "description": "Profesjonalna fotografia na konferencje, eventy firmowe i wydarzenia branżowe. Zdjęcia w 24h, retusz w cenie, obsługa w całej Polsce.",
    "url": "https://imprezowyfotograf.pl/oferta/fotograf-na-konferencje-krakow",
    "image": "https://imprezowyfotograf.pl/assets/images/covers/konferencje_cover.jpg",
    "areaServed": [
      {"@type": "City", "name": "Kraków"},
      {"@type": "City", "name": "Warszawa"},
      {"@type": "City", "name": "Katowice"},
      {"@type": "City", "name": "Rzeszów"},
      {"@type": "City", "name": "Tarnów"},
      {"@type": "City", "name": "Kielce"},
      {"@type": "Country", "name": "Polska"}
    ],
    "serviceType": ["Fotografia konferencyjna", "Fotografia eventowa", "Fotografia firmowa", "Zdjęcia live"],
    "priceRange": "$$",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Pakiety fotografii konferencyjnej",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Pakiet Brązowy - Podstawowy",
            "description": "1 fotograf, do 4h reportażu, 100 zdjęć po obróbce, retusz w cenie, dostawa w 24h"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Pakiet Srebrny - Rozszerzony",
            "description": "1 fotograf, do 8h reportażu, 200 zdjęć po obróbce, retusz w cenie, dostawa w 24h"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Pakiet Złoty - Premium+",
            "description": "2 fotografów lub więcej, do 10h reportażu, 400+ zdjęć po obróbce, retusz w cenie, dostawa w 24h"
          }
        }
      ]
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "50"
    }
  })} />

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Ile kosztuje fotograf na konferencję?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cena fotografa na konferencję zależy od wybranego pakietu. Pakiet podstawowy (do 4h, 100 zdjęć) zaczyna się od 1500 zł, pakiet rozszerzony (do 8h, 200 zdjęć) od 2000 zł, a pakiet premium z dwoma fotografami (do 10h, 400+ zdjęć) od 2500 zł. Wszystkie pakiety zawierają retusz zdjęć w cenie."
        }
      },
      {
        "@type": "Question",
        "name": "Jak szybko otrzymam zdjęcia z konferencji?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Zdjęcia z konferencji dostarczamy w ciągu 24 godzin od zakończenia wydarzenia. Oferujemy również usługę zdjęć live, gdzie pierwsze partie zdjęć trafiają do klienta jeszcze w trakcie trwania eventu dzięki obecności fotoedytora na miejscu."
        }
      },
      {
        "@type": "Question",
        "name": "Czy retuszujecie zdjęcia z konferencji?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tak! W przeciwieństwie do wielu fotografów eventowych, my retuszujemy wszystkie zdjęcia z konferencji w cenie usługi. Wiemy, jak ważny jest profesjonalny wygląd osób na zdjęciach biznesowych przeznaczonych do promocji na LinkedIn, Facebooku czy Instagramie."
        }
      },
      {
        "@type": "Question",
        "name": "Na jakim terenie fotografujecie konferencje?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Konferencje i eventy branżowe fotografujemy głównie na terenie Krakowa, Tarnowa, Rzeszowa, Warszawy, Katowic oraz Kielc, ale dojeżdżamy na terenie całej Polski. Realizujemy również reportaże poza granicami kraju."
        }
      },
      {
        "@type": "Question",
        "name": "Czy oferujecie również nagrania wideo z konferencji?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tak, oprócz reportażu fotograficznego oferujemy relacje wideo, teledyski, spoty promocyjne, rejestrację wywiadów i wypowiedzi, streaming live oraz inne formy filmowe dostosowane do potrzeb klienta."
        }
      }
    ]
  })} />

  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Zarezerwuj fotografa',
        href: '/kontakt',
      },
      {
        variant: 'secondary',
        text: 'Zobacz portfolio',
        href: '/portfolio',
      },
    ]}
    image={{ 
      src: KonferencjeCover, 
      alt: 'Fotograf na konferencje - profesjonalna fotografia eventowa Kraków'
    }}
  >
    <Fragment slot="title">
      Fotograf na Konferencję i Eventy Firmowe
    </Fragment>

    <Fragment slot="subtitle">
      Fotografia eventowa to nie tylko rejestrowanie przebiegu zdarzeń, ale także <strong>opowiadanie historii</strong>. Skupiamy się na kluczowych momentach, interakcjach między uczestnikami oraz atmosferze spotkania. <strong>Zdjęcia w 24h</strong>, retusz w cenie, obsługa w całej Polsce.
    </Fragment>
  </Hero>

  <!-- Main Content - Rich SEO Content -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
          Fotografujemy konferencje i wydarzenia branżowe
        </h2>
        <div class="prose prose-lg dark:prose-invert max-w-none text-gray-600 dark:text-gray-400">
          <p class="mb-4">
            Fotografia eventowa to nie tylko rejestrowanie przebiegu zdarzeń, ale także opowiadanie historii. Podczas fotografowania konferencji i wydarzeń branżowych skupiamy się na kluczowych momentach nakreślonych przez zlecającego, interakcjach między uczestnikami oraz odpowiednim uchwyceniu atmosfery spotkania. Zwracamy także uwagę na emocje i detale. Tworząc relację skupiamy się na wykonaniu jak najlepszych kadrów, jednocześnie staramy się nie przeszkadzać i nie zwracać na siebie uwagi uczestników wydarzenia.
          </p>
          <p class="mb-4">
            W przypadku konferencji dość często organizatorom zależy na szybkim otrzymaniu zdjęć — do promocji na <strong>LinkedIn</strong>, <strong>Facebooku</strong> czy <strong>Instagramie</strong>. Z tego powodu czas oddania materiału z konferencji skracamy do minimum. Zwykle jest to od <strong>12 do 48 godzin</strong> od zakończenia imprezy. Oferujemy również tzw. <strong>zdjęcia live</strong> — jeśli jest taka konieczność, na lokację oprócz fotografa przyjeżdża również fotoedytor. Dzięki takiemu rozwiązaniu pierwsze partie zdjęć trafiają do Was jeszcze w czasie trwania eventu.
          </p>
          <p class="mb-4">
            Niewielu fotografów retuszuje skórę osób na zdjęciach eventowych, ponieważ retusz zabiera sporo czasu. My jednak wiemy, jak ważny jest dobry wygląd osób na naszych zdjęciach i dlatego <strong>retuszujemy wszystkie zdjęcia</strong>!
          </p>
          <p class="mb-4">
            Konferencje i inne eventy branżowe fotografujemy zwykle na terenie <strong>Krakowa</strong>, <strong>Tarnowa</strong>, <strong>Rzeszowa</strong>, <strong>Warszawy</strong>, <strong>Katowic</strong> oraz <strong>Kielc</strong>, ale dojeżdżamy na terenie całej Polski. Zdarza nam się również realizować reportaże poza granicami kraju. Miejsce nie ma dla nas znaczenia — dojedziemy i dolecimy gdzie trzeba.
          </p>
          <p>
            <strong>Nagrywamy również filmy!</strong> Oprócz reportażu fotograficznego oferujemy także relacje wideo, teledyski, spoty promocyjne, rejestrację wywiadów i wypowiedzi, streaming live oraz inne formy filmowe — w zależności od potrzeb konkretnego klienta.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Details -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4 text-center">
        Jakie wydarzenia firmowe fotografujemy?
      </h2>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-12 max-w-2xl mx-auto">
        Obsługujemy szeroki zakres wydarzeń biznesowych — od konferencji po imprezy integracyjne.
      </p>
      
      <Features
        items={[
          {
            title: 'Konferencje branżowe',
            description: 'Profesjonalna dokumentacja konferencji i kongresów branżowych — prelekcje, panele dyskusyjne, networking.',
            icon: 'tabler:presentation',
          },
          {
            title: 'Imprezy firmowe i bankiety',
            description: 'Obsługa fotograficzna gali, bankietów, wigilii firmowych i imprez integracyjnych.',
            icon: 'tabler:building',
          },
          {
            title: 'Wyjazdy integracyjne',
            description: 'Fotografia z wyjazdów firmowych, team buildingów i spotkań pracowników.',
            icon: 'tabler:mountain',
          },
          {
            title: 'Targi i wystawy',
            description: 'Dokumentacja targów branżowych, wystaw i eventów promocyjnych.',
            icon: 'tabler:shopping-cart',
          },
          {
            title: 'Szkolenia i warsztaty',
            description: 'Zdjęcia ze szkoleń, warsztatów, sesji trainingowych i spotkań rozwojowych.',
            icon: 'tabler:school',
          },
          {
            title: 'Spotkania biznesowe',
            description: 'Dokumentacja ważnych spotkań biznesowych, negocjacji i podpisywania umów.',
            icon: 'tabler:users',
          },
        ]}
      />
    </div>
  </section>

  <!-- Pricing -->
  <Pricing
    title="Oferta — fotograf na konferencję"
    subtitle="Wybierz pakiet, który odpowiada Twoim oczekiwaniom, albo skontaktuj się z nami w celu dopasowania oferty specjalnie dla Ciebie!"
    prices={[
      {
        title: 'Brązowy',
        subtitle: 'Pakiet podstawowy',
        price: 'od 1500 zł',
        period: '1 fotograf / dzień',
        items: [
          {
            description: '100 zdjęć po obróbce',
          },
          {
            description: 'Do 4h reportażu',
          },
          {
            description: 'Retusz w cenie',
          },
          {
            description: 'Dostawa w 24h',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Zarezerwuj pakiet',
          href: '/kontakt',
        },
      },
      {
        title: 'Srebrny',
        subtitle: 'Pakiet rozszerzony',
        price: 'od 2000 zł',
        period: '1 fotograf / dzień',
        items: [
          {
            description: '200 zdjęć po obróbce',
          },
          {
            description: 'Do 8h reportażu',
          },
          {
            description: 'Retusz w cenie',
          },
          {
            description: 'Dostawa w 24h',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Zarezerwuj pakiet',
          href: '/kontakt',
        },
        hasRibbon: true,
        ribbonTitle: 'Popularny',
      },
      {
        title: 'Złoty',
        subtitle: 'Pakiet Premium+',
        price: 'od 2500 zł',
        period: '2 fotografów (lub więcej) / dzień',
        items: [
          {
            description: '400+ zdjęć po obróbce',
          },
          {
            description: 'Do 10h reportażu',
          },
          {
            description: 'Retusz w cenie',
          },
          {
            description: 'Dostawa w 24h',
          },
        ],
        callToAction: {
          target: '_self',
          text: 'Zarezerwuj pakiet',
          href: '/kontakt',
        },
      },
    ]}
  />

  <!-- Additional Options -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4 text-center">
        Opcje dodatkowe
      </h2>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-12 max-w-2xl mx-auto">
        Do pakietów można dobrać opcje dodatkowe. Istnieje również możliwość skomponowania oferty od podstaw bazując na Waszych oczekiwaniach.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="bg-white dark:bg-gray-900 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Dodatkowy fotograf</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">+1 fotograf / 4 godziny, czyli +100 zdjęć do pakietu.</p>
        </div>
        
        <div class="bg-white dark:bg-gray-900 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Ścianka fotograficzna</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Zdjęcia na jednolitym lub zaaranżowanym tle — idealne na eventy firmowe.</p>
        </div>
        
        <div class="bg-white dark:bg-gray-900 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Ścianka live</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Zdjęcia „w czasie rzeczywistym" na udostępnionym serwerze.</p>
        </div>
        
        <div class="bg-white dark:bg-gray-900 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Fotoedytor na miejscu</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Zdjęcia z wydarzenia „w czasie rzeczywistym" na serwerze — idealne do social media.</p>
        </div>
        
        <div class="bg-white dark:bg-gray-900 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
