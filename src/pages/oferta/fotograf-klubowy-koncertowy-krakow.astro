---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Gallery from '~/components/widgets/Gallery.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';
import OfferFaq from '~/components/offer/OfferFaq.astro';

import imprezyKluboweCover from '~/assets/images/covers/klubowe_cover.jpg';
import { createOfferPageGraph, siteUrl } from '~/utils/schema';

const faqData = [
  { question: "Ile kosztuje fotograf na koncert?", answer: "Ceny fotografa na koncert w Krakowie zależą od długości wydarzenia, liczby fotografów oraz zakresu usług. Dla reportażu eventowego najczęściej wynoszą od <strong>250 do 500 zł za godzinę</strong>, co obejmuje obróbkę zdjęć i dostawę materiałów." },
  { question: "Jak przygotować klub do sesji zdjęciowej podczas koncertu?", answer: "Zabezpieczcie przede wszystkim dostęp do głównej sceny — to najważniejsza rzecz, o którą prosimy organizatorów. Nic nie musisz dodatkowo przygotowywać: my przyjeżdżamy z własnym sprzętem (aparatami Full Frame, jasnymi obiektywami f/1.4 i lampami reporterskimi) i dostosowujemy się do warunków oświetleniowych typowych dla klubów. Jeśli planujesz również zdjęcia za kulisami, wystarczy oznajmić, że potrzebujesz dostępu do strefy backstage. Po imprezie dostarczamy gotowe, obrobione zdjęcia w ciągu 24–48 godzin." },
  { question: "Ile kosztuje fotograf eventowy?", answer: "Fotograf eventowy w Krakowie pobiera zazwyczaj od <strong>200 do 600 zł za godzinę</strong>. Stawka dzienna (day rate) dla wydarzeń trwających 8–10 godzin może wynosić od 2 000 do 5 000 zł, w zależności od doświadczenia i zakresu usług." },
];

const faqSchemaItems = faqData.map(q => ({ name: q.question, acceptedAnswer: { text: q.answer } }));

const schema = createOfferPageGraph({
  serviceName: "Fotograf Klubowy i Koncertowy Kraków",
  serviceDescription: "Profesjonalna fotografia na koncerty, imprezy klubowe i festiwale w Krakowie i całej Polsce. Dynamiczne zdjęcia z wydarzeń muzycznych, retusz w cenie.",
  serviceUrl: `${siteUrl}/oferta/fotograf-klubowy-koncertowy-krakow`,
  faqItems: faqSchemaItems,
  breadcrumbItems: [
    { position: 1, name: "Strona główna", item: siteUrl },
    { position: 2, name: "Oferta", item: `${siteUrl}/oferta` },
    { position: 3, name: "Fotograf klubowy i koncertowy" },
  ],
});

const metadata = {
  title: 'Fotografia Koncertowa i Klubowa w Krakowie — Profesjonalne Zdjęcia z Koncertów | ImprezowyFotograf',
  description: 'Profesjonalna fotografia koncertowa i klubowa w Krakowie. Sprzęt Full Frame, jasne obiektywy f/1.4, obróbka w cenie, dostawa nawet w 24h. Sprawdź ofertę!',
  canonical: 'https://imprezowyfotograf.pl/oferta/fotograf-klubowy-koncertowy-krakow',
  openGraph: {
    url: 'https://imprezowyfotograf.pl/oferta/fotograf-klubowy-koncertowy-krakow',
    images: [
      {
        url: imprezyKluboweCover,
        width: 1200,
        height: 630,
      },
    ],
    locale: 'pl_PL',
    type: 'website',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Zarezerwuj fotografa',
        href: '/kontakt',
      },
      {
        variant: 'secondary',
        text: 'Zobacz portfolio',
        href: '/portfolio',
      },
    ]}
    image={{ 
      src: imprezyKluboweCover, 
      alt: 'Fotografia koncertowa i klubowa w Krakowie'
    }}
  >
    <Fragment slot="title">
      Fotograf Klubowy i Koncertowy Kraków
    </Fragment>

    <Fragment slot="subtitle">
      Profesjonalna fotografia koncertowa i klubowa w Krakowie — dynamiczne zdjęcia z koncertów, festiwali i imprez muzycznych, dostarczane nawet w 24h.
    </Fragment>
  </Hero>

  <!-- 🔴 NOWA SEKCJA: Fotografia koncertowa i klubowa w Krakowie -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">Fotografia koncertowa i klubowa w Krakowie</h2>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        Jeśli szukasz <strong>fotografa na koncert Kraków</strong>, który uchwyci całą energię występów na żywo, jesteś w dobrym miejscu. Specjalizujemy się w <strong>fotografii koncertowej w Krakowie</strong> — zarówno podczas małych klubowych spotkań muzycznych, jak i podczas dużych imprez festiwalowych. Nasza praca to dynamiczne zdjęcia z wydarzeń muzycznych, które oddają emocje artystów oraz atmosferę publiczności.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        Jako <strong>fotograf klubowy Kraków</strong> pracujemy w trudnych warunkach oświetleniowych typowych dla scen muzycznych. Służymy doświadczeniem i odpowiednim sprzętem: profesjonalne aparaty Full Frame oraz jasne obiektywy f/1.4–2.8, które pozwalają na uchwycenie nawet najsłabszych punktów świetlnych podczas występu.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto text-center">
        Wykonujemy również <strong>fotografię z festiwali w Krakowie</strong> i w całej Polsce — od kilkunastogodzinnych reportaży po sesje zdjęciowe z zespołami i solistami przed lub po występie. Jeśli potrzebujesz <strong>reportażu z wydarzeń muzycznych w Krakowie</strong> — zapraszamy do kontaktu. Najpierw omawiamy wszystkie szczegóły podczas bezpłatnej konsultacji.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Fotografia na żywo</h2>
          <div class="space-y-4">
            <div class="flex items-start space-x-3">
              <div class="w-6 h-6 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Doświadczenie klubowe</h3>
                <p class="text-gray-600 dark:text-gray-400">Wieloletnie doświadczenie w fotografii klubowej i koncertowej w trudnych warunkach oświetleniowych.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-3">
              <div class="w-6 h-6 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Dynamiczne kadry</h3>
                <p class="text-gray-600 dark:text-gray-400">Uchwycenie ruchu, energii i emocji koncertu w dynamicznych, artystycznych kadrach.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-3">
              <div class="w-6 h-6 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-purple-600 dark:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Szybka realizacja</h3>
                <p class="text-gray-600 dark:text-gray-400">Zdjęcia z koncertu gotowe w ciągu 24-48 godzin dla mediów i promocji.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div>
          <img src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80" alt="Fotografia klubowa i koncertowa" class="rounded-lg shadow-lg">
        </div>
      </div>
    </div>
  </section>

  <OfferFaq
    heading="Najczęstsze pytania — fotografia koncertowa"
    items={faqData}
  />

  <!-- Services Details -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Nasze usługi koncertowe</h2>
      
      <Features
        items={[
          {
            title: 'Koncerty live',
            description: 'Profesjonalna dokumentacja koncertów od małych klubów po duże festiwale.',
            icon: 'tabler:music',
          },
          {
            title: 'Imprezy klubowe',
            description: 'Fotografia z wydarzeń klubowych, house parties i eventów muzycznych.',
            icon: 'tabler:brand-telegram',
          },
          {
            title: 'Festiwale',
            description: 'Kompleksowa obsługa fotograficzna festiwali muzycznych.',
            icon: 'tabler:campfire',
          },
          {
            title: 'Zdjęcia za kulisami',
            description: 'Wyjątkowe ujęcia z backstage przed koncertem i podczas przygotowań.',
            icon: 'tabler:camera-off',
          },
          {
            title: 'Portrety artystów',
            description: 'Profesjonalne portrety muzyków i zespołów przed występem.',
            icon: 'tabler:user-circle',
          },
          {
            title: 'Public relations',
            description: 'Zdjęcia dla mediów, prasy i materiały promocyjne.',
            icon: 'tabler:news',
          },
        ]}
      />
    </div>
  </section>

  <!-- Equipment -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Nasz sprzęt</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0118.07 6H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Aparaty</h3>
          <p class="text-gray-600 dark:text-gray-400">Profesjonalne lustrzanki Full Frame do fotografii w trudnych warunkach.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Obiektywy</h3>
          <p class="text-gray-600 dark:text-gray-400">Jasne obiektywy f/1.4-2.8 idealne na koncerty i klubowe warunki.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Oświetlenie</h3>
          <p class="text-gray-600 dark:text-gray-400">Profesjonalne lampy reporterskie i studyjne do doskonałego oświetlenia.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Jak pracujemy?</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-purple-600 dark:text-purple-400">1</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Konsultacja</h3>
          <p class="text-gray-600 dark:text-gray-400">Omawiamy szczegóły wydarzenia i wymagania organizatora.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-purple-600 dark:text-purple-400">2</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Przygotowanie</h3>
          <p class="text-gray-600 dark:text-gray-400">Sprzęt gotowy przed rozpoczęciem wydarzenia.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-purple-600 dark:text-purple-400">3</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Dokumentacja</h3>
          <p class="text-gray-600 dark:text-gray-400">Profesjonalna fotografia podczas całego wydarzenia.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-xl font-bold text-purple-600 dark:text-purple-400">4</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Postprodukcja</h3>
          <p class="text-gray-600 dark:text-gray-400">Szybka obróbka i dostarczenie materiałów.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Gallery -->
  <Gallery 
    folderPath="portfolio/dyskoteka" 
    title="Portfolio"
    subtitle="Poniżej wrzucamy trochę kadrów pokazujących, jak mogą wyglądać zdjęcia z Waszej dyskoteki!"
    minColumnWidth={200}
    gap={12}
  />

  <!-- Contact Form -->
  <ContactForm
    formName="formularz-klubowe"
    title="Zarezerwuj fotografa na koncert lub imprezę klubową"
    description="Wypełnij formularz, a skontaktujemy się z Tobą w sprawie fotografii klubowej lub koncertowej."
  />
</Layout>
