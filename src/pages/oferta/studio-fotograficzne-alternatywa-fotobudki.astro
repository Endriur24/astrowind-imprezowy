---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Gallery from '~/components/widgets/Gallery.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';
import OfferFaq from '~/components/offer/OfferFaq.astro';
import { createOfferPageGraph, siteUrl } from '~/utils/schema';

import studioCover from '~/assets/images/covers/studio_fotograficzne_cover.jpg';

const faqData = [
  {
    question: 'Ile kosztuje studio fotograficzne na wesele lub imprezę?',
    answer:
      'Cena zależy od czasu trwania, liczby gości i lokalizacji. Napisz do nas z datą, miejscem i orientacyjną liczbą gości — odezwiemy się z wyceną w ciągu <strong>24 godzin</strong>.',
  },
  {
    question: 'Czym różni się dostarczanie zdjęć 1:1 od zwykłej galerii online?',
    answer:
      'Przy klasycznej galerii jeden link prowadzi do zdjęć wszystkich gości — każdy, kto go dostanie, może przewijać zdjęcia innych osób. W naszym modelu <strong>1:1</strong> każdy gość skanuje własny, indywidualny kod i dostaje wyłącznie swoje zdjęcia. Nikt poza Tobą nie ma do nich dostępu, chyba że sam zdecydujesz się je udostępnić.',
  },
  {
    question: 'Czy goście muszą instalować aplikację, żeby odebrać zdjęcie?',
    answer:
      'Nie. Skanowanie kodu QR otwiera zdjęcie bezpośrednio w przeglądarce telefonu — <strong>bez logowania</strong> i bez instalowania czegokolwiek.',
  },
  {
    question: 'Ile osób możecie sfotografować w ciągu godziny?',
    answer:
      'Szacunkowo <strong>20–50 zdjęć na godzinę</strong> przy jednym stanowisku — dokładną liczbę potwierdzamy na bazie pierwszych realizacji. Przy większej liczbie gości możemy rozstawić dwa stanowiska równolegle.',
  },
  {
    question: 'Czy dojeżdżacie poza Kraków?',
    answer:
      'Tak, obsługujemy wydarzenia na terenie całej <strong>Polski</strong>. Koszt dojazdu uwzględniamy w wycenie.',
  },
  {
    question: 'Czy możemy też otrzymać wspólną galerię z najlepszymi zdjęciami?',
    answer:
      'Tak — to opcja, nie domyślne ustawienie. Para młoda lub solenizant może zamówić dodatkową, wybraną <strong>galerię najlepszych ujęć</strong> z całej imprezy, niezależnie od prywatnych zdjęć 1:1 trafiających do poszczególnych gości.',
  },
];

const faqSchemaItems = faqData.map((q) => ({ name: q.question, acceptedAnswer: { text: q.answer } }));

const schema = createOfferPageGraph({
  serviceName: 'Mobilne Studio Fotograficzne — Alternatywa Fotobudki',
  serviceDescription:
    'Mobilne studio fotograficzne na wesele i imprezy w Krakowie. Zdjęcia cyfrowe 1:1 — prosto do gościa, bez wspólnej galerii dla wszystkich. Wydruk na miejscu.',
  serviceUrl: `${siteUrl}/oferta/studio-fotograficzne-alternatywa-fotobudki`,
  faqItems: faqSchemaItems,
  breadcrumbItems: [
    { position: 1, name: 'Strona główna', item: siteUrl },
    { position: 2, name: 'Oferta', item: `${siteUrl}/oferta` },
    { position: 3, name: 'Alternatywa fotobudki' },
  ],
});

const metadata = {
  title: 'Alternatywa Fotobudki na Wesele i Imprezy — Zdjęcia 1:1',
  description:
    'Szukasz alternatywy dla fotobudki na wesele? Nasze mobilne studio fotograficzne z wydrukiem na miejscu dostarcza zdjęcia 1:1 — prosto do gościa, bez wspólnej galerii dla wszystkich. Kraków i cała Polska.',
  canonical: 'https://imprezowyfotograf.pl/oferta/studio-fotograficzne-alternatywa-fotobudki',
  openGraph: {
    url: 'https://imprezowyfotograf.pl/oferta/studio-fotograficzne-alternatywa-fotobudki',
    locale: 'pl_PL',
    type: 'website',
    title: 'Alternatywa Fotobudki na Wesele i Imprezy — Zdjęcia 1:1',
    description:
      'Mobilne studio fotograficzne z wydrukiem na miejscu. Zdjęcia trafiają tylko do Ciebie — bez wspólnej galerii dla wszystkich gości.',
    image: '/og-default.jpg',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero Section -->
  <Hero
    image={{
      src: studioCover,
      alt: 'Mobilne studio fotograficzne na imprezie',
    }}
    actions={[
      {
        variant: 'primary',
        text: 'Zapytaj o wycenę',
        href: '#formularz-studio-fotograficzne',
      },
      {
        variant: 'secondary',
        text: 'Zobacz portfolio',
        href: '#gallery-offers-studio-na-impreze',
      },
    ]}
  >
    <Fragment slot="title">Fotobudka? Coś więcej</Fragment>

    <Fragment slot="subtitle">
      Nasze <strong>mobilne studio fotograficzne</strong> to alternatywa fotobudki na wesele, studniówkę, osiemnastkę czy
      imprezę firmową: profesjonalny fotograf zamiast automatu, wydruk na miejscu i zdjęcia cyfrowe
      <strong>1:1</strong> — prosto do telefonu konkretnej osoby, bez wspólnej galerii dla wszystkich gości.
    </Fragment>
  </Hero>

  <!-- SEO Content Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">
        Alternatywa fotobudki, która nie zostawia zdjęć Twoich gości w ogólnym dostępie
      </h2>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        Szukasz <strong>alternatywy dla fotobudki na wesele</strong> albo inną imprezę w Krakowie? Nasze
        <strong>mobilne studio fotograficzne</strong> to coś więcej niż automat z rekwizytami:
        <strong>profesjonalny fotograf prowadzący sesję</strong>, wydruk gotowy jeszcze podczas imprezy oraz cyfrowa
        wersja zdjęcia w pełnej rozdzielczości — dostarczana <strong>wyłącznie osobie, która jest na zdjęciu</strong>.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto text-center">
        Realizujemy mobilnym studiem fotograficznym głównie w <strong>Krakowie i Małopolsce</strong>, ale dojeżdżamy
        również do innych miast w całej <strong>Polsce</strong>.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">
          Dlaczego to nie jest zwykła fotobudka
        </h2>
        <div class="space-y-4">
          <div class="flex items-start space-x-3">
            <div
              class="w-6 h-6 bg-teal-100 dark:bg-teal-900 rounded-full flex items-center justify-center flex-shrink-0 mt-1"
            >
              <svg class="w-3 h-3 text-teal-600 dark:text-teal-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Prywatność 1:1</h3>
              <p class="text-gray-600 dark:text-gray-400">
                Każdy gość otrzymuje link tylko do swoich zdjęć — nie do galerii z twarzami wszystkich uczestników
                imprezy.
              </p>
            </div>
          </div>

          <div class="flex items-start space-x-3">
            <div
              class="w-6 h-6 bg-teal-100 dark:bg-teal-900 rounded-full flex items-center justify-center flex-shrink-0 mt-1"
            >
              <svg class="w-3 h-3 text-teal-600 dark:text-teal-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Wydruk od ręki</h3>
              <p class="text-gray-600 dark:text-gray-400">
                Pamiątkowa odbitka trafia do gościa jeszcze podczas trwania imprezy, bez czekania do następnego dnia.
              </p>
            </div>
          </div>

          <div class="flex items-start space-x-3">
            <div
              class="w-6 h-6 bg-teal-100 dark:bg-teal-900 rounded-full flex items-center justify-center flex-shrink-0 mt-1"
            >
              <svg class="w-3 h-3 text-teal-600 dark:text-teal-400" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Jakość studyjna</h3>
              <p class="text-gray-600 dark:text-gray-400">
                Profesjonalne oświetlenie, kadrowanie i retusz — prowadzi fotograf, nie automat z rekwizytami.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Details -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">
        Co obejmuje nasze studio fotograficzne
      </h2>

      <Features
        items={[
          {
            title: 'Prywatna dystrybucja 1:1',
            description: 'Każde zdjęcie trafia indywidualnym linkiem tylko do osoby, która jest na fotografii.',
            icon: 'tabler:lock',
          },
          {
            title: 'Fotograf, nie automat',
            description: 'Profesjonalista prowadzi kadr, ustawia pozę i dba o jakość każdego ujęcia.',
            icon: 'tabler:camera',
          },
          {
            title: 'Wydruk na miejscu',
            description: 'Elegancka odbitka gotowa do odbioru w kilka minut od zrobienia zdjęcia.',
            icon: 'tabler:printer',
          },
          {
            title: 'Cyfrowa wersja po retuszu',
            description:
              'Pełna rozdzielczość, gotowa do pobrania i publikacji — jeśli gość sam zdecyduje się ją udostępnić.',
            icon: 'tabler:wand',
          },
          {
            title: 'Opcjonalna galeria hitów',
            description: 'Dla pary młodej lub solenizanta — osobna, wybrana galeria najlepszych ujęć z całej imprezy.',
            icon: 'tabler:photo',
          },
          {
            title: 'Personalizacja tła i ramki',
            description: 'Dopasowanie scenerii i oprawy zdjęcia do charakteru wydarzenia.',
            icon: 'tabler:palette',
          },
        ]}
      />
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Jak przebiega sesja?</h2>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div
            class="w-16 h-16 bg-teal-100 dark:bg-teal-900 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-xl font-bold text-teal-600 dark:text-teal-400">1</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Rozstawiamy studio</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Profesjonalne oświetlenie i tło w wybranym miejscu sali lub imprezy — ok. 30–45 minut przed rozpoczęciem.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 bg-teal-100 dark:bg-teal-900 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-xl font-bold text-teal-600 dark:text-teal-400">2</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Fotografujemy gości</h3>
          <p class="text-gray-600 dark:text-gray-400">
            W parach, grupach lub indywidualnie — przez cały czas trwania sesji, w tempie dopasowanym do kolejki.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 bg-teal-100 dark:bg-teal-900 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-xl font-bold text-teal-600 dark:text-teal-400">3</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Wydruk w kilka minut</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Gość dostaje odbitkę do ręki jeszcze na imprezie — nie musi na nią czekać do następnego dnia.
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 bg-teal-100 dark:bg-teal-900 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-xl font-bold text-teal-600 dark:text-teal-400">4</span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Prywatny link 1:1</h3>
          <p class="text-gray-600 dark:text-gray-400">
            Gość skanuje swój indywidualny kod QR i dostaje wyłącznie swoje zdjęcia — bez logowania, bez aplikacji.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Video: skanowanie QR -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Zobacz, jak to działa</h2>
          <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed mb-6">
            Gość skanuje kod QR telefonem — zdjęcie pojawia się natychmiast na ekranie, bez logowania i instalowania
            aplikacji.
          </p>
          <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed">
            Cały proces zajmuje kilka sekund: aparat w telefonie rozpoznaje kod, przeglądarka otwiera się sama, a
            zdjęcie w pełnej rozdzielczości czeka już gotowe do pobrania lub udostępnienia.
          </p>
        </div>
        <div class="flex justify-center lg:justify-end">
          <div
            class="relative w-full max-w-md aspect-square rounded-xl overflow-hidden shadow-2xl border-4 border-gray-900 dark:border-gray-700 bg-gray-900"
          >
            <video
              src="/videos/skanowanie_kodu_qr.mp4"
              autoplay
              loop
              muted
              playsinline
              class="w-full h-full object-cover"
              id="studio-qr-video"></video>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline data-astro-rerun>
    (function() {
      const video = document.getElementById('studio-qr-video');
      if (!video) return;
      const played = false;
      function tryPlay() {
        if (played) return;
        played = true;
        const p = video.play();
        if (p && p.catch) p.catch(function() {});
      }
      video.load();
      video.addEventListener('loadeddata', tryPlay, { once: true });
      video.addEventListener('canplay', tryPlay, { once: true });
      setTimeout(tryPlay, 1500);
    })();
  </script>

  <!-- Comparison: fotobudka vs nasze studio -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">
        Studio fotograficzne czy fotobudka? To nie to samo
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white dark:bg-gray-900 rounded-lg p-8 border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">
            Klasyczna fotobudka lub inne mobilne studio
          </h3>
          <ul class="space-y-3">
            <li class="flex items-start text-gray-600 dark:text-gray-400">
              <svg
                class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              Automat albo jeden fotograf bez wsparcia operatora
            </li>
            <li class="flex items-start text-gray-600 dark:text-gray-400">
              <svg
                class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              Zdjęcia lądują we wspólnej galerii online — widzi je każdy, kto ma link
            </li>
            <li class="flex items-start text-gray-600 dark:text-gray-400">
              <svg
                class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              Żeby znaleźć swoje zdjęcie, trzeba przewinąć dziesiątki cudzych
            </li>
            <li class="flex items-start text-gray-600 dark:text-gray-400">
              <svg
                class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              Zero kontroli nad tym, kto zobaczy Twoje ujęcie z imprezy
            </li>
          </ul>
        </div>

        <div class="bg-teal-600 text-white rounded-lg p-8 border-2 border-teal-600">
          <h3 class="text-xl font-bold mb-6">Studio fotograficzne Imprezowy Fotograf</h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-white mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              Fotograf + operator druku pracujący razem przez cały czas trwania sesji
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-white mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              Zdjęcia trafiają 1:1 — tylko do osoby, która jest na fotografii
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-white mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              Swoje zdjęcie masz od razu w telefonie, bez przeszukiwania niczego
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-white mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              To Ty decydujesz, czy i gdzie chcesz swoje zdjęcie udostępnić
            </li>
          </ul>
        </div>
      </div>

      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mt-8 text-center">
        Wspólna galeria z imprezy to zdjęcia dziesiątek osób w jednym miejscu — łącznie z ujęciami, których część gości
        wolałaby nie widzieć w publicznym obiegu. Model 1:1 ogranicza to ryzyko już na starcie, bo nikt poza
        właścicielem zdjęcia nie dostaje do niego dostępu.
      </p>
    </div>
  </section>

  <!-- Dla jakich wydarzeń -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">
        Dla jakich wydarzeń sprawdza się nasze studio fotograficzne
