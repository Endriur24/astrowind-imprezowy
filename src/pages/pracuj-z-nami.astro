---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';
import { createGenericPageSchema, siteUrl } from '~/utils/schema';

const schema = createGenericPageSchema({
  name: 'Pracuj z nami - ImprezowyFotograf',
  url: `${siteUrl}/pracuj-z-nami`,
  description: 'Chcesz z nami pracować? Fotografować, filmować lub obrabiać materiały? Skontaktuj się z nami!',
  breadcrumbItems: [
    { position: 1, name: 'Strona główna', item: siteUrl },
    { position: 2, name: 'Pracuj z nami' },
  ],
});

const metadata = {
  title: 'Pracuj z nami - ImprezowyFotograf',
  description: 'Chcesz z nami pracować? Fotografować, filmować lub obrabiać materiały? Skontaktuj się z nami!',
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Wyślij aplikację',
        href: '#kontakt'
      }
    ]}
  >
    <Fragment slot="title">
      Zacznij pracować z naszym zespołem!
    </Fragment>
    <Fragment slot="subtitle">
      Chcesz z nami pracować? Fotografować, filmować, a może zajmować się obróbką zdjęć, bądź montażem filmów?<br>
      Napisz do nas, zobaczymy, co da się zrobić!
    </Fragment>
  </Hero>

  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">Kogo szukamy?</h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-12 text-center">Jesteśmy otwarci na współpracę z osobami o różnym poziomie doświadczenia. Jeśli czujesz, że to coś dla Ciebie — napisz do nas!</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
            <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0118.07 6H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Fotografowie</h3>
            <p class="text-gray-600 dark:text-gray-400">Doświadczenie w fotografii eventowej, reportażowej, klubowej lub ślubnej. Własny sprzęt (aparat pełnoklatkowy, lampy błyskowe) mile widziany.</p>
          </div>

          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
            <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Operatorzy kamery / Filmowcy</h3>
            <p class="text-gray-600 dark:text-gray-400">Doświadczenie w nagraniach eventowych, teledyskach lub streamingu. Umiejętność montażu w Adobe Premiere Pro lub DaVinci Resolve.</p>
          </div>

          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
            <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Fotoedytorzy</h3>
            <p class="text-gray-600 dark:text-gray-400">Biegła obsługa Adobe Lightroom Classic i Photoshop. Umiejętność szybkiej selekcji i retuszu zdjęć eventowych.</p>
          </div>

          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700">
            <div class="w-12 h-12 bg-amber-100 dark:bg-amber-900 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Marketing i social media</h3>
            <p class="text-gray-600 dark:text-gray-400">Zarządzanie profilami w social mediach, tworzenie treści, analiza statystyk. Kreatywność i znajomość trendów mile widziane.</p>
          </div>
        </div>

        <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-8 border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Co oferujemy?</h3>
          <ul class="space-y-3 text-gray-600 dark:text-gray-400">
            <li class="flex items-start">
              <span class="text-blue-600 dark:text-blue-400 mr-2">•</span>
              <span>Elastyczne godziny — dopasowujemy się do Twojego grafiku</span>
            </li>
            <li class="flex items-start">
              <span class="text-blue-600 dark:text-blue-400 mr-2">•</span>
              <span>Ciekawe i zróżnicowane zlecenia — od studniówek po wyjazdy zagraniczne</span>
            </li>
            <li class="flex items-start">
              <span class="text-blue-600 dark:text-blue-400 mr-2">•</span>
              <span>Możliwość rozwoju — dzielimy się wiedzą i doświadczeniem</span>
            </li>
            <li class="flex items-start">
              <span class="text-blue-600 dark:text-blue-400 mr-2">•</span>
              <span>Praca w zespole pasjonatów fotografii i wideo</span>
            </li>
            <li class="flex items-start">
              <span class="text-blue-600 dark:text-blue-400 mr-2">•</span>
              <span>Możliwość współpracy zarówno na stałe, jak i przy pojedynczych projektach</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div id="kontakt"></div>
  <ContactForm
    formName="formularz-pracuj-z-nami"
    title="Aplikuj do zespołu"
    description="Opisz krótko siebie, swoje doświadczenie i w jakiej roli widzisz siebie w naszym zespole. Dołącz link do portfolio, jeśli posiadasz."
  />
</Layout>
