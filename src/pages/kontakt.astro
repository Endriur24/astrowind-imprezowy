---
import Layout from '~/layouts/PageLayout.astro';
import { createGenericPageSchema, siteUrl } from '~/utils/schema';

import Hero from '~/components/widgets/Hero.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

const schema = createGenericPageSchema({
  name: 'Kontakt - ImprezowyFotograf',
  url: `${siteUrl}/kontakt`,
  description: 'Skontaktuj się z nami, aby omówić fotografię na Twoje wydarzenie. Profesjonalna fotografia eventowa w Krakowie.',
  breadcrumbItems: [
    { position: 1, name: 'Strona główna', item: siteUrl },
    { position: 2, name: 'Kontakt' },
  ],
});

const metadata = {
  title: 'Kontakt - ImprezowyFotograf',
  description: 'Skontaktuj się z nami, aby omówić fotografię na Twoje wydarzenie. Profesjonalna fotografia eventowa.',
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero Section -->
  <Hero>
    <Fragment slot="title">
      Napisz do nas!
    </Fragment>

    <Fragment slot="subtitle">
      Jeśli nasza oferta Cię zainteresowała - nie wahaj się! Wypełnij formularz kontaktowy! Daj znać jakie wydarzenie chcesz uwiecznić i zostaw do siebie kontakt. Odpiszemy najszybciej jak to możliwe!
    </Fragment>
  </Hero>

  <ContactForm
    title="Wyślij wiadomość"
    description="Wypełnij formularz kontaktowy, a skontaktujemy się z Tobą najszybciej jak to możliwe."
  />
        

</Layout>
