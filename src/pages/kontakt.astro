---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import ContactForm from '~/components/widgets/ContactForm.astro';

const metadata = {
  title: 'Kontakt - ImprezowyFotograf',
  description: 'Skontaktuj się z nami, aby omówić fotografię na Twoje wydarzenie. Profesjonalna fotografia eventowa.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero>
    <Fragment slot="title">
      Napisz do nas!
    </Fragment>

    <Fragment slot="subtitle">
      Jeśli nasza oferta Cię zainteresowała - nie wahaj się! Wypełnij formularz kontaktowy! Daj znać jakie wydarzenie chcesz uwiecznić i zostaw do siebie kontakt. Odpiszemy najszybciej jak to możliwe!
    </Fragment>
  </Hero>

  <ContactForm
    title="Wyślij wiadomość"
    description="Wypełnij formularz kontaktowy, a skontaktujemy się z Tobą najszybciej jak to możliwe."
  />
        

</Layout>
