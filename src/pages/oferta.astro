---
import Layout from '~/layouts/PageLayout.astro';
import ImageGrid from '~/components/widgets/ImageGrid.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { createHomePageSchema } from '~/utils/schema';

// Import covers from src/assets/images
import coverStudniowki from '~/assets/images/covers/studniowki_cover.jpg';
import coverStudenckie from '~/assets/images/covers/imprezy_studenckie_cover.jpg';
import coverKlubowe from '~/assets/images/covers/klubowe_cover.jpg';
import coverKonferencje from '~/assets/images/covers/konferencje_cover.jpg';
import coverEventowy from '~/assets/images/covers/eventowy_cover.jpg';
import coverUrodzinowe from '~/assets/images/covers/urodzinowe_cover.jpg';
import coverZdjeciaLive from '~/assets/images/covers/zdjecia_live_cover.jpg';
import coverSpecjalne from '~/assets/images/covers/repo_specjalne_cover.jpg';
import coverDodatkowe from '~/assets/images/covers/dodatkowe_uslugi_cover.jpg';
import coverStudio from '~/assets/images/covers/studio_fotograficzne_cover.jpg';
import coverVideo from '~/assets/images/covers/video_eventowe_cover.jpg';
import coverStreaming from '~/assets/images/covers/streaming_video_cover.jpg';
import coverSzkolenia from '~/assets/images/covers/szkolenia_cover.jpg';

const metadata = {
  title: 'Fotograf Imprezowy Kraków — Usługi Fotograficzne i Wideo na Eventy | ImprezowyFotograf',
  description: 'Profesjonalny fotograf imprezowy w Krakowie. Zdjęcia na studniówki, konferencje, imprezy klubowe, eventy firmowe, urodziny i wiele więcej. Retusz w cenie, dostawa 24-72h. Sprawdź pełną ofertę!',
  canonical: 'https://imprezowyfotograf.pl/oferta',
  openGraph: {
    url: 'https://imprezowyfotograf.pl/oferta',
    locale: 'pl_PL',
    type: 'website',
    title: 'Fotograf Imprezowy Kraków — Usługi Fotograficzne i Wideo na Eventy',
    description: 'Profesjonalny fotograf imprezowy w Krakowie. Studniówki, konferencje, eventy firmowe, kluby, urodziny. Retusz w cenie, dostawa 24-72h.',
  },
  twitter: {
    cardType: 'summary_large_image',
  },
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(createHomePageSchema())} />

  <!-- SEO Content Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-800">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6 text-center">Profesjonalny fotograf imprezowy w Krakowie</h2>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        Szukasz <strong>fotografa na imprezę w Krakowie</strong>? Jesteś w dobrym miejscu! Jako <strong>ImprezowyFotograf</strong> oferujemy kompleksowe <strong>usługi fotograficzne i wideo</strong> na każdą okazję — od <strong>studniówek</strong> i <strong>imprez studenckich</strong>, przez <strong>konferencje</strong> i <strong>eventy firmowe</strong>, aż po <strong>imprezy klubowe</strong>, <strong>urodziny</strong> i <strong>projekty specjalne</strong>.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto mb-6 text-center">
        Wszystkie nasze pakiety zawierają <strong>retusz zdjęć w cenie</strong> — w przeciwieństwie do większości fotografów na rynku. Standardowy czas dostarczenia materiałów to od <strong>24 do 72 godzin</strong> od zakończenia wydarzenia, a dzięki usłudze <strong>zdjęć live</strong> pierwsze zdjęcia mogą trafić do Ciebie jeszcze w trakcie trwania eventu.
      </p>
      <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed max-w-3xl mx-auto text-center">
        Działamy głównie na terenie <strong>Krakowa</strong>, <strong>Tarnowa</strong>, <strong>Rzeszowa</strong>, <strong>Warszawy</strong>, <strong>Katowic</strong> oraz <strong>Kielc</strong>, ale dojeżdżamy na terenie <strong>całej Polski</strong> — a jeśli tego wymaga wydarzenie, również za granicą.
      </p>
    </div>
  </section>

  <ImageGrid
    title="Nasza Oferta"
    columns={3}
    items={[
      {
        image: {
          src: coverStudniowki,
          alt: 'Fotograf na studniówkę w Krakowie'
        },
        title: 'Fotograf na studniówkę / komers',
        description: 'Profesjonalna fotografia studniówkowa w Krakowie. Pakiety od 1 do 3+ fotografów, zdjęcia grupowe klas, ścianka, teledysk wideo i retusz w cenie.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/fotograf-na-studniowke'
        }
      },
      {
        image: {
          src: coverStudenckie,
          alt: 'Fotograf na imprezę studencką w Krakowie'
        },
        title: 'Fotograf na imprezę studencką',
        description: 'Bale wydziałowe, dyskoteki, rajdy studenckie, puchar dziekana — profesjonalna fotografia akademicka w Krakowie i całej Polsce.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/fotograf-na-wydarzenia-studenckie'
        }
      },
      {
        image: {
          src: coverKlubowe,
          alt: 'Fotograf klubowy i koncertowy Kraków'
        },
        title: 'Fotograf klubowy / koncertowy',
        description: 'Dynamiczne zdjęcia z koncertów i imprez klubowych w Krakowie. Profesjonalny sprzęt Full Frame, jasne obiektywy, dostarcza zdjęć w 24h.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/fotograf-klubowy-koncertowy-krakow'
        }
      },
      {
        image: {
          src: coverKonferencje,
          alt: 'Fotograf na konferencję w Krakowie'
        },
        title: 'Fotograf na konferencję',
        description: 'Profesjonalna fotografia konferencyjna i eventowa. Zdjęcia w 24h, retusz w cenie, zdjęcia live na social media.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/fotograf-na-konferencje-krakow'
        }
      },
      {
        image: {
          src: coverEventowy,
          alt: 'Fotograf na event firmowy w Krakowie'
        },
        title: 'Fotograf na event firmowy',
        description: 'Zdjęcia z eventów firmowych, urodziny firmy, otwarcia biur, szkoleń, wyjazdów integracyjnych. Retusz w cenie, dostawa 24-72h.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/fotograf-eventowy-krakow'
        }
      },
      {
        image: {
          src: coverUrodzinowe,
          alt: 'Fotograf na urodziny w Krakowie'
        },
        title: 'Fotograf na urodziny / 18-tkę',
        description: 'Profesjonalna fotografia urodzinowa w Krakowie. Osiemnastki, urodziny dziecięce i dorosłych. Pakiety od 600 zł.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/fotograf-na-urodziny-krakow'
        }
      },
      {
        image: {
          src: coverZdjeciaLive,
          alt: 'Zdjęcia live na eventy w Krakowie'
        },
        title: 'Zdjęcia live',
        description: 'Dostarczanie zdjęć w czasie rzeczywistym podczas trwania wydarzenia. Fotoedytor na miejscu, szybka publikacja na social media.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/zdjecia-live'
        }
      },
      {
        image: {
          src: coverSpecjalne,
          alt: 'Reportaże i projekty specjalne'
        },
        title: 'Reportaże specjalne',
        description: 'Reportaże z wyjazdów na zawody, eventy sportowe i zjazdy samochodowe. Doświadczenie w USA, Europie i nie tylko.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/reportaze-i-projekty-specjalne'
        }
      },
      {
        image: {
          src: coverDodatkowe,
          alt: 'Dodatkowe usługi fotograficzne'
        },
        title: 'Dodatkowe usługi foto/wideo',
        description: 'Fotobudka, ścianka fotograficzna live, zdjęcia z drona, streaming, zdjęcia instant i inne atrakcje na eventy.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/dodatkowe-uslugi-fotograficzne'
        }
      },
      {
        image: {
          src: coverStudio,
          alt: 'Studio fotograficzne na imprezę'
        },
        title: 'Studio fotograficzne — alternatywa fotobudki',
        description: 'Mobilne studio fotograficzne z wydrukiem na miejscu. Zdjęcia 1:1 trafiają tylko do osoby na fotografii, bez wspólnej galerii.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/studio-fotograficzne-alternatywa-fotobudki'
        }
      },
      {
        image: {
          src: coverVideo,
          alt: 'Wideo eventowe Kraków'
        },
        title: 'Wideo eventowe',
        description: 'Teledyski z eventów, spoty promocyjne, nagrania wykładów, filmy z drona i materiały wizerunkowe.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/video-eventowe'
        }
      },
      {
        image: {
          src: coverStreaming,
          alt: 'Streaming wideo z konferencji'
        },
        title: 'Streaming wideo',
        description: 'Transmisje live z konferencji, wykładów i eventów. Pełna obsługa AV, webinary, programy dedykowane.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/streaming-video'
        }
      },
      {
        image: {
          src: coverSzkolenia,
          alt: 'Szkolenia fotograficzne i wideo Kraków'
        },
        title: 'Szkolenia foto i wideo',
        description: 'Warsztaty grupowe i konsultacje 1:1: Lightroom, Premiere Pro, fotografia reportażowa, światło studyjne i więcej.',
        link: {
          text: 'Sprawdź ofertę!',
          href: '/oferta/szkolenia-foto-wideo'
        }
      }
    ]}
  />

  <!-- FAQ Section -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="container px-4 mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Najczęstsze pytania — usługi fotograficzne</h2>
      <div class="max-w-3xl mx-auto space-y-8">
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Ile kosztuje fotograf na imprezę w Krakowie?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Cena fotografa na imprezę w Krakowie zależy od rodzaju wydarzenia, liczby godzin i zakresu usług. Stawka godzinowa wynosi zazwyczaj od <strong>200 do 600 zł</strong>, a stawka dzienna od <strong>2 000 do 5 000 zł</strong>. Wszystkie pakiety zawierają retusz zdjęć w cenie.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Jak szybko otrzymam zdjęcia z imprezy?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Standardowy czas dostarczenia zdjęć z imprezy to <strong>5-7 dni roboczych</strong> od zakończenia wydarzenia. Istnieje możliwość szybszego oddania w <strong>72h lub 24h</strong>. Oferujemy również usługę <strong>live edit</strong>, gdzie zdjęcia oddawane są jeszcze w trakcie trwania wydarzenia.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Czy retuszujecie zdjęcia z imprez?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Tak! W przeciwieństwie do wielu fotografów imprezowych, my <strong>retuszujemy wszystkie zdjęcia</strong> w cenie usługi. Wiemy, jak ważny jest dobry wygląd osób na zdjęciach przeznaczonych do publikacji w social media.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Na jakim terenie fotografujecie imprezy?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Fotografujemy imprezy głównie na terenie <strong>Krakowa</strong>, <strong>Tarnowa</strong>, <strong>Rzeszowa</strong>, <strong>Warszawy</strong>, <strong>Katowic</strong> oraz <strong>Kielc</strong>, ale dojeżdżamy na terenie <strong>całej Polski</strong> i za granicą.
          </p>
        </div>
        <div class="border-b border-gray-200 dark:border-gray-700 pb-6">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Jakie usługi fotograficzne oferujecie?</h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            Oferujemy kompleksowe usługi fotograficzne i wideo: <strong>zdjęcia na studniówki</strong>, <strong>imprezy studenckie</strong>, <strong>eventy firmowe</strong>, <strong>konferencje</strong>, <strong>imprezy klubowe</strong>, <strong>urodziny</strong>, <strong>zdjęcia live</strong>, <strong>streaming wideo</strong>, <strong>wideo eventowe</strong>, <strong>reportaże specjalne</strong>, <strong>szkolenia foto</strong> oraz <a href="/oferta/dodatkowe-uslugi-fotograficzne" class="text-blue-600 dark:text-blue-400 hover:underline">dodatkowe usługi</a> takie jak fotobudka, <a href="/oferta/studio-fotograficzne-alternatywa-fotobudki" class="text-blue-600 dark:text-blue-400 hover:underline">studio fotograficzne</a> czy ścianka fotograficzna.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Napisz do nas',
        href: '/kontakt'
      },
      {
        variant: 'secondary',
        text: 'Zadzwoń: +48 885 195 599',
        href: 'tel:+48885195599'
      }
    ]}
  >
    <Fragment slot="title">
      Masz pytania?
    </Fragment>
    <Fragment slot="subtitle">
      Skontaktuj się z nami, aby omówić szczegóły oferty dopasowanej do Twoich potrzeb
    </Fragment>
  </CallToAction>
</Layout>
